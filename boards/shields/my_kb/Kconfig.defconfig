if SHIELD_MY_KB_LEFT
    config ZMK_KEYBOARD_NAME
    	default "my_kb_left"
    config ZMK_SPLIT_ROLE_CENTRAL
        default y
endif

if SHIELD_MY_KB_RIGHT

    config ZMK_SPLIT_ROLE_CENTRAL
        default n
endif

if SHIELD_MY_KB_LEFT || SHIELD_MY_KB_RIGHT

    config ZMK_SPLIT
            default y

endif