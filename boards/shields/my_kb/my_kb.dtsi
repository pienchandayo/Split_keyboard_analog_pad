#include <dt-bindings/zmk/matrix_transform.h>

#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/mouse.h> 
#include <input/processors.dtsi>
#include <physical_layouts.dtsi>

#define MAP(row, col) ((row * 16) + col)
/ {
    chosen {
        zmk,kscan = &kscan_composite;
        zmk,matrix_transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <16>; /* 14 + 左右各1 = 16 */
        rows = <5>;
        map = <
            /* 左手(0-6)                                                        右手(7-13)                                                              左joy-con       右joy-con */
            MAP(0,6) MAP(0,5) MAP(0,4) MAP(0,3) MAP(0,2) MAP(0,1)                        MAP(0,8) MAP(0,9) MAP(0,10) MAP(0,11) MAP(0,12) MAP(0,13)      MAP(0,14)   MAP(0,15)
            MAP(1,6) MAP(1,5) MAP(1,4) MAP(1,3) MAP(1,2) MAP(1,1)                        MAP(1,8) MAP(1,9) MAP(1,10) MAP(1,11) MAP(1,12) MAP(1,13)
            MAP(2,6) MAP(2,5) MAP(2,4) MAP(2,3) MAP(2,2) MAP(2,1) MAP(2,0)      MAP(2,7) MAP(2,8) MAP(2,9) MAP(2,10) MAP(2,11) MAP(2,12) MAP(2,13)
            MAP(3,6) MAP(3,5) MAP(3,4) MAP(3,3) MAP(3,2) MAP(3,1) MAP(3,0)      MAP(3,7) MAP(3,8) MAP(3,9) MAP(3,10) MAP(3,11) MAP(3,12) MAP(3,13)
            MAP(4,6) MAP(4,5)          MAP(4,3) MAP(4,2) MAP(4,1) MAP(4,0)      MAP(4,7) MAP(4,8) MAP(4,9) MAP(4,10)           MAP(4,12) MAP(4,13)
        >;
    };

    /* 既存のマトリックス（.overlayでピン定義） */
    kscan0: kscan {
            compatible = "zmk,kscan-gpio-matrix";
            label = "KSCAN";
            diode-direction = "col2row";
    };

    /* P0.31 の単体スイッチ定義 */
    kscan_direct: kscan_direct {
        compatible = "zmk,kscan-gpio-direct";
        label = "DIRECT_KSCAN";
        //input-gpios
        //  = <&gpio0 31 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
    };

    /* 合成設定 */
    kscan_composite: kscan_composite {
        compatible = "zmk,kscan-composite";
        label = "COMPOSITE_KSCAN";
        rows = <5>;
        columns = <16>;

        matrix {
            kscan = <&kscan0>;
        };

        /* 左手側の追加スイッチを15列目(14)に配置 */
        direct_left {
            kscan = <&kscan_direct>;
            row-offset = <0>;
            column-offset = <14>;
        };

        /* 右手側の追加スイッチを16列目(15)に配置 */
        /* 分割キーボードでは、各サイドのkscanが合算されるため、
           右手側のkscan_directも自動的にこのスロットに入ります */
        direct_right {
            kscan = <&kscan_direct>;
            row-offset = <0>;
            column-offset = <15>;
        };
    };
    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan0>;
        keys  //                     w   h   x  y   rot rx ry
            =	<&key_physical_attrs 100 100 50 100 50 100 0 >
            ,	<&key_physical_attrs 100 100 150 100 150 100 0 >
            ,	<&key_physical_attrs 100 100 250 75 250 75 0 >
            ,	<&key_physical_attrs 100 100 350 50 350 50 0 >
            ,	<&key_physical_attrs 100 100 450 100 450 100 0 >
            ,	<&key_physical_attrs 100 100 550 100 550 100 0 >
            ,	<&key_physical_attrs 100 100 650 100 650 100 0 >
            ,	<&key_physical_attrs 100 100 1050 100 1050 100 0 >
            ,	<&key_physical_attrs 100 100 1150 100 1150 100 0 >
            ,	<&key_physical_attrs 100 100 1250 100 1250 100 0 >
            ,	<&key_physical_attrs 100 100 1350 50 1350 50 0 >
            ,	<&key_physical_attrs 100 100 1450 75 1450 75 0 >
            ,	<&key_physical_attrs 100 100 1550 100 1550 100 0 >
            ,	<&key_physical_attrs 100 100 1650 100 1650 100 0 >
            ,	<&key_physical_attrs 100 100 750 700 750 700 0 >
            ,	<&key_physical_attrs 100 100 950 700 950 700 0 >
            ,	<&key_physical_attrs 100 100 50 200 50 200 0 >
            ,	<&key_physical_attrs 100 100 150 200 150 200 0 >
            ,	<&key_physical_attrs 100 100 250 175 250 175 0 >
            ,	<&key_physical_attrs 100 100 350 150 350 150 0 >
            ,	<&key_physical_attrs 100 100 450 200 450 200 0 >
            ,	<&key_physical_attrs 100 100 550 200 550 200 0 >
            ,	<&key_physical_attrs 100 100 650 200 650 200 0 >
            ,	<&key_physical_attrs 100 100 1050 200 1050 200 0 >
            ,	<&key_physical_attrs 100 100 1150 200 1150 200 0 >
            ,	<&key_physical_attrs 100 100 1250 200 1250 200 0 >
            ,	<&key_physical_attrs 100 100 1350 150 1350 150 0 >
            ,	<&key_physical_attrs 100 100 1450 175 1450 175 0 >
            ,	<&key_physical_attrs 100 100 1550 200 1550 200 0 >
            ,	<&key_physical_attrs 100 100 1650 200 1650 200 0 >
            ,	<&key_physical_attrs 100 100 50 300 50 300 0 >
            ,	<&key_physical_attrs 100 100 150 300 150 300 0 >
            ,	<&key_physical_attrs 100 100 250 275 250 275 0 >
            ,	<&key_physical_attrs 100 100 350 250 350 250 0 >
            ,	<&key_physical_attrs 100 100 450 300 450 300 0 >
            ,	<&key_physical_attrs 100 100 550 300 550 300 0 >
            ,	<&key_physical_attrs 100 100 650 300 650 300 0 >
            ,	<&key_physical_attrs 100 100 1050 300 1050 300 0 >
            ,	<&key_physical_attrs 100 100 1150 300 1150 300 0 >
            ,	<&key_physical_attrs 100 100 1250 300 1250 300 0 >
            ,	<&key_physical_attrs 100 100 1350 250 1350 250 0 >
            ,	<&key_physical_attrs 100 100 1450 275 1450 275 0 >
            ,	<&key_physical_attrs 100 100 1550 300 1550 300 0 >
            ,	<&key_physical_attrs 100 100 1650 300 1650 300 0 >
            ,	<&key_physical_attrs 100 100 50 400 50 400 0 >
            ,	<&key_physical_attrs 100 100 150 400 150 400 0 >
            ,	<&key_physical_attrs 100 100 250 375 250 375 0 >
            ,	<&key_physical_attrs 100 100 350 350 350 350 0 >
            ,	<&key_physical_attrs 100 100 450 400 450 400 0 >
            ,	<&key_physical_attrs 100 100 550 400 550 400 0 >
            ,	<&key_physical_attrs 100 100 650 400 650 400 0 >
            ,	<&key_physical_attrs 100 100 1050 400 1050 400 0 >
            ,	<&key_physical_attrs 100 100 1150 400 1150 400 0 >
            ,	<&key_physical_attrs 100 100 1250 400 1250 400 0 >
            ,	<&key_physical_attrs 100 100 1350 350 1350 350 0 >
            ,	<&key_physical_attrs 100 100 1450 375 1450 375 0 >
            ,	<&key_physical_attrs 100 100 1550 400 1550 400 0 >
            ,	<&key_physical_attrs 100 100 1650 400 1650 400 0 >
            ,	<&key_physical_attrs 100 100 50 500 50 500 0 >
            ,	<&key_physical_attrs 100 100 150 500 150 500 0 >
            ,	<&key_physical_attrs 100 100 250 475 250 475 0 >
            ,	<&key_physical_attrs 100 100 350 450 350 450 0 >
            ,	<&key_physical_attrs 100 100 450 500 450 500 0 >
            ,	<&key_physical_attrs 100 100 550 500 550 500 0 >
            ,	<&key_physical_attrs 100 100 650 500 650 500 0 >
            ,	<&key_physical_attrs 100 100 1050 500 1050 500 0 >
            ,	<&key_physical_attrs 100 100 1150 500 1150 500 0 >
            ,	<&key_physical_attrs 100 100 1250 500 1250 500 0 >
            ,	<&key_physical_attrs 100 100 1350 450 1350 450 0 >
            ,	<&key_physical_attrs 100 100 1450 475 1450 475 0 >
            ,	<&key_physical_attrs 100 100 1550 500 1550 500 0 >
            ,	<&key_physical_attrs 100 100 1650 500 1650 500 0 >
            ,	<&key_physical_attrs 100 100 50 600 50 600 0 >
            ,	<&key_physical_attrs 100 100 150 600 150 600 0 >
            ,	<&key_physical_attrs 100 100 250 575 250 575 0 >
            ,	<&key_physical_attrs 100 100 350 550 350 550 1000 >
            ,	<&key_physical_attrs 100 200 450 650 450 650 1500 >
            ,	<&key_physical_attrs 100 100 650 700 650 700 0 >
            ,	<&key_physical_attrs 100 100 750 800 750 800 0 >
            ,	<&key_physical_attrs 100 100 950 800 950 800 0 >
            ,	<&key_physical_attrs 100 100 1050 700 1050 700 1500 >
            ,	<&key_physical_attrs 100 200 1250 650 1250 650 1000 >
            ,	<&key_physical_attrs 100 100 1350 550 1350 550 0 >
            ,	<&key_physical_attrs 100 100 1450 575 1450 575 0 >
            ,	<&key_physical_attrs 100 100 1550 600 1550 600 0 >
            ,	<&key_physical_attrs 100 100 1650 600 1650 600 0 >
            ;	

    };
};